# Backend
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.1-8b-instant

# OpenSearch — LOCAL (Docker Compose)
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASS=admin
OPENSEARCH_USE_SSL=false

# OpenSearch — CLOUD (Bonsai / Aiven / AWS / dll.)
# Jika OPENSEARCH_URL diisi, variabel OPENSEARCH_HOST/PORT/USER/PASS di atas diabaikan.
# Format: https://user:password@hostname:port
# OPENSEARCH_URL=https://user:password@your-cluster.bonsaisearch.net:443

# Frontend (Vercel)
VITE_API_URL=https://your-backend.up.railway.app
